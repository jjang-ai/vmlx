# vMLX Swift release signing environment.
#
# Copy to `.env.signing` and fill in real values — the file is gitignored.
# Source it before running `scripts/build-release.sh`:
#
#   cd swift
#   cp .env.signing.example .env.signing
#   $EDITOR .env.signing
#   source .env.signing
#   scripts/build-release.sh 2.0.0
#
# Apple ID that owns the Developer ID Application cert.
export NOTARIZE_APPLE_ID="you@example.com"

# Developer Team ID (10-char). Visit developer.apple.com/account to find it.
export NOTARIZE_TEAM_ID="YOURTEAMID"

# App-specific password generated at appleid.apple.com.
# DO NOT commit the real value. Rotate via appleid.apple.com if leaked.
export NOTARIZE_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Common name of the Developer ID Application cert in Keychain, e.g.
# "Developer ID Application: Your Name (YOURTEAMID)".
export CODESIGN_IDENTITY="Developer ID Application"
